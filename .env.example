# Environment Variables
# Copy this file to .env.local and fill in the values

# Site URL
NEXT_PUBLIC_SITE_URL=https://WorldPDF.com

# SiteGround Node.js App
# SiteGround uses PORT environment variable automatically
PORT=3000

# Security
CSRF_SECRET=your-csrf-secret-key-here
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# File Processing (optional - for server-side processing)
MAX_FILE_SIZE_MB=50
FILE_RETENTION_MINUTES=60

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Database (optional - for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/WorldPDF

# Redis (optional - for caching)
# REDIS_URL=redis://localhost:6379
