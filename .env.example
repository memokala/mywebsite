# WorldPDF Environment Variables Configuration
# Copy this file to .env.local and fill in the real credentials.

# Next.js Server Port
PORT=3000

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth (Auth.js) Secrets
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-32-chars-long

# OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Database - Neon Postgres URL
DATABASE_URL=postgresql://user:password@localhost:5432/worldpdf

# Redis / Vercel KV for session rate-limiting
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# SMTP Mail Server for Email verification & password resets
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_your_api_key
SMTP_FROM=no-reply@myworldpdf.com

# PayPal Sandbox & Production credentials
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_PLAN_ID_PRO=your-paypal-pro-plan-id
PAYPAL_PLAN_ID_BUSINESS=your-paypal-business-plan-id

# Binance Pay Merchant credentials
BINANCE_API_KEY=your-binance-merchant-api-key
BINANCE_API_SECRET=your-binance-merchant-api-secret
